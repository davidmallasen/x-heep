`verilator_config

lint_off -rule LITENDIAN -file "*/src/periph_to_reg.sv" -match "Little bit endian vector*"
lint_off -rule UNUSED -file "*/src/reg_demux.sv" -match "*"
lint_off -rule UNOPTFLAT -file "*/src/periph_to_reg.sv" -match "*"
lint_off -rule DECLFILENAME -file "*/src/reg_cdc.sv" -match "Filename 'reg_cdc' does not match MODULE name: 'reg_cdc_src'"
lint_off -rule DECLFILENAME -file "*/src/apb_to_reg.sv" -match "Filename 'apb_to_reg' does not match MODULE name: 'apb_to_reg_intf'"
lint_off -rule DECLFILENAME -file "*/src/axi_lite_to_reg.sv" -match "Filename 'axi_lite_to_reg' does not match MODULE name: 'axi_lite_to_reg_intf'"
